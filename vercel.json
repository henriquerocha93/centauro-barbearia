{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/app_v14.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/AgendamentoFacil/index.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!AgendamentoFacil|master|assets|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
